{
  "name": "vibefixing",
  "version": "0.1.2",
  "description": "AI-powered code analysis and auto-fixing CLI tool",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "vibefixing": "./dist/bin/vibefixing.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "cosmiconfig": "^9.0.0",
    "fast-glob": "^3.3.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/open-neo/vibefixing.git"
  },
  "homepage": "https://github.com/open-neo/vibefixing",
  "bugs": {
    "url": "https://github.com/open-neo/vibefixing/issues"
  },
  "keywords": [
    "cli",
    "code-analysis",
    "ai",
    "security",
    "linting",
    "auto-fix"
  ]
}
